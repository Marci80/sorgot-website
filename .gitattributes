# Normalize line endings for text files (checked out as LF).
* text=auto eol=lf

# Treat media and fonts as binary: no EOL/whitespace processing.
*.mp3  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.otf  binary
*.ttf  binary
*.woff binary
*.woff2 binary

# --- Git LFS (currently OFF) ---
# Audio is stored as plain git files for now (total expected under ~500 MB).
# If the audio library grows past ~500 MB, switch MP3s to Git LFS:
#   1. git lfs install
#   2. uncomment the line below
#   3. git add .gitattributes
#   4. git add --renormalize public/audio
#   5. commit and push (and add `with: lfs: true` to the deploy workflow checkout)
# *.mp3 filter=lfs diff=lfs merge=lfs -text
