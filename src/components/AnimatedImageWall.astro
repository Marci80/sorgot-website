---
import { homeImages } from '../data/homeImages.js';

// Split images evenly across 5 columns so no image repeats across columns.
// Each column gets its own unique slice, then that slice is doubled for
// the seamless infinite-scroll trick (the second copy is the "reset" half).
const NUM_COLS = 5;

function chunkForColumn(images: string[], colIndex: number, total: number): string[] {
  const perCol = Math.ceil(images.length / total);
  const start  = colIndex * perCol;
  const slice  = images.slice(start, start + perCol);
  // Double the slice so the CSS animation can loop seamlessly (translateY -50%)
  return [...slice, ...slice];
}

const columns = [
  { direction: 'up',   duration: '180s', images: chunkForColumn(homeImages, 0, NUM_COLS) },
  { direction: 'down', duration: '220s', images: chunkForColumn(homeImages, 1, NUM_COLS) },
  { direction: 'up',   duration: '160s', images: chunkForColumn(homeImages, 2, NUM_COLS) },
  { direction: 'down', duration: '200s', images: chunkForColumn(homeImages, 3, NUM_COLS) },
  { direction: 'up',   duration: '240s', images: chunkForColumn(homeImages, 4, NUM_COLS) },
];
---

<section
  id="image-wall"
  class="relative overflow-hidden"
  style="height: 70vh; min-height: 400px;"
  aria-label="גלריית תמונות מונפשת"
>
  <!-- Image grid -->
  <div class="flex gap-2 h-full px-2">
    {columns.map((col) => (
      <div
        class="wall-col flex-1 overflow-hidden"
        style="min-width: 0;"
      >
        <div
          class={`col-${col.direction} flex flex-col gap-2`}
          style={`animation-duration: ${col.duration};`}
        >
          {col.images.map((src, i) => {
            const webpSrc = src.replace(/\.(jpg|jpeg|png)$/i, '.webp');
            return (
              <div class="rounded-xl overflow-hidden flex-shrink-0">
                <picture>
                  <source srcset={webpSrc} type="image/webp" />
                  <img
                    src={src}
                    alt="תמונה מתערוכת הסריגה"
                    class="w-full object-cover block"
                    style="height: 220px;"
                    loading={i < 6 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </picture>
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </div>

  <!-- Top fade -->
  <div
    class="absolute inset-x-0 top-0 pointer-events-none"
    style="height: 60px; background: linear-gradient(to bottom, white, transparent);"
    aria-hidden="true"
  ></div>

  <!-- Bottom fade -->
  <div
    class="absolute inset-x-0 bottom-0 pointer-events-none"
    style="height: 60px; background: linear-gradient(to top, white, transparent);"
    aria-hidden="true"
  ></div>
</section>

<p class="text-center text-xs text-gray-400 mt-2 mb-0 px-4">
  קרדיט תמונות: תמי בר שי ויפית צרפתי. צילומי רחפן: עידו בר שי
</p>

<script>
  const wall   = document.getElementById('image-wall') as HTMLElement;
  const strips = wall.querySelectorAll<HTMLElement>('.col-up, .col-down');

  // Stop permanently the moment the user scrolls — never resume.
  let stopped = false;

  function stopWall() {
    if (stopped) return;
    stopped = true;
    strips.forEach(el => el.style.animationPlayState = 'paused');
    window.removeEventListener('scroll', stopWall, { capture: true });
  }

  window.addEventListener('scroll', stopWall, { passive: true, capture: true });
</script>

<!-- Mobile: show only 2 columns; tablet: 3 columns -->
<style>
  @media (max-width: 767px) {
    .wall-col:nth-child(n+3) { display: none; }
    #image-wall { height: 50vh !important; min-height: 260px !important; }
    .col-up img, .col-down img { height: 130px !important; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .wall-col:nth-child(n+4) { display: none; }
    .col-up img, .col-down img { height: 180px !important; }
  }
</style>
