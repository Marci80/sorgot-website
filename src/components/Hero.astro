---
// Hero welcoming text — edit directly to update content.
// Heading and body extracted from "welcome text.docx".
const heading = 'תערוכת הסורגות - בורגתה';

const paragraphs = [
  'תערוכת הסריגה הקהילתית בבורגתה לזכרה של זהבה שחורי ז"ל מזמינה אתכם לטיול מרגש בין יצירות שבהן כל חוט נושא עמו רגש, געגוע או תקווה.',
  'המיצגים המרשימים בתערוכה נסרגו באהבה על ידי עשרות נשים מעמק חפר ומרחבי הארץ, במלאכת יד מוקפדת.',
  'היצירה מסמלת את הכוח שבשיתופי פעולה, את החיבוק הקהילתי, ואת התקווה לסרוג יחד עתיד טוב ומואר יותר.',
];
---

<section class="py-24 md:py-32 px-4 sm:px-6" aria-labelledby="hero-heading">
  <div class="max-w-2xl mx-auto text-center">

    <h1
      id="hero-heading"
      class="text-4xl sm:text-5xl font-bold text-burgundy mb-8 leading-tight font-abraham"
    >
      {heading}
    </h1>

    <div class="space-y-5 text-xl text-gray-600 leading-relaxed">
      {paragraphs.map((p) => (
        <p>{p}</p>
      ))}
    </div>

    <!-- CTA button -->
    <div class="mt-12">
      <a
        href={`${import.meta.env.BASE_URL}register`}
        class="inline-block bg-burgundy hover:bg-burgundy-dark text-white text-lg font-medium px-10 py-4 rounded-full transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-burgundy"
      >
        להצטרפות לקבוצה
      </a>
    </div>

  </div>
</section>
