---
---

<footer class="bg-gray-50 border-t border-gray-200 py-10 mt-16" role="contentinfo">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">

    <!-- Social icons -->
    <div class="flex justify-center gap-6 mb-6" aria-label="רשתות חברתיות">
      <!-- Instagram -->
      <a
        href="#"
        aria-label="Instagram"
        class="text-gray-400 hover:text-burgundy transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-burgundy rounded"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" fill="none"/>
          <circle cx="12" cy="12" r="4" stroke="currentColor" fill="none"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
        </svg>
      </a>

      <!-- Facebook -->
      <a
        href="#"
        aria-label="Facebook"
        class="text-gray-400 hover:text-burgundy transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-burgundy rounded"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
        </svg>
      </a>

      <!-- WhatsApp -->
      <a
        href="#"
        aria-label="WhatsApp"
        class="text-gray-400 hover:text-burgundy transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-burgundy rounded"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12c0 4.97-4.03 9-9 9a8.96 8.96 0 01-4.48-1.19L3 21l1.22-4.38A8.96 8.96 0 013 12c0-4.97 4.03-9 9-9s9 4.03 9 9z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/>
        </svg>
      </a>
    </div>

    <!-- Contact -->
    <p class="text-sm text-gray-500 mb-3">
      צרו קשר:
      <a
        href="mailto:example@email.com"
        class="text-burgundy hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-burgundy rounded"
      >
        example@email.com
      </a>
    </p>

    <!-- Copyright -->
    <p class="text-xs text-gray-400">© 2025 תערוכת הסריגה השנתית</p>
  </div>
</footer>
