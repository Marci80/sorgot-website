---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL;

// Ploni font weights served from public/fonts/. Injected with the BASE_URL
// prefix so the font files resolve under the GitHub Pages subpath.
const fontFaces = [
  ['ploni-ultralight-aaa', 100],
  ['ploni-light-aaa', 300],
  ['ploni-regular-aaa', 400],
  ['ploni-medium-aaa', 500],
  ['ploni-demibold-aaa', 600],
  ['ploni-bold-aaa', 700],
  ['ploni-ultrabold-aaa', 800],
  ['ploni-black-aaa', 900],
]
  .map(
    ([file, weight]) =>
      `@font-face{font-family:'Ploni';src:url('${base}fonts/${file}.otf') format('opentype');font-weight:${weight};font-style:normal;font-display:swap;}`
  )
  .join('\n');

const customFontFaces = `
@font-face{font-family:'Abraham';src:url('${base}fonts/Abraham-Regular.woff') format('woff');font-weight:400;font-style:normal;font-display:swap;}
@font-face{font-family:'FbTipograf';src:url('${base}fonts/FbTipograf-Regular.woff2') format('woff2'),url('${base}fonts/FbTipograf-Regular.otf') format('opentype');font-weight:400;font-style:normal;font-display:swap;}
@font-face{font-family:'FbTipograf';src:url('${base}fonts/FbTipograf-Bold.woff2') format('woff2');font-weight:700;font-style:normal;font-display:swap;}
`;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'תערוכת הסריגה השנתית',
  description = 'תערוכת הסריגה הקהילתית — יצירות מוקפדות, חיבור קהילתי ואהבה לאומנות',
} = Astro.props;
---

<!doctype html>
<html lang="he" dir="rtl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <!-- Self-hosted font faces (BASE_URL-prefixed) -->
    <style set:html={fontFaces}></style>
    <style set:html={customFontFaces}></style>
  </head>
  <body class="bg-white text-gray-800 font-fbtipograf antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
