---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="תודה — תערוכת הסריגה השנתית">

  <section class="min-h-[60vh] flex flex-col items-center justify-center px-4 py-24 text-center" dir="rtl" lang="he">
    <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6 leading-tight">
      תודה שנרשמת!
    </h1>
    <p class="text-xl text-gray-700 mb-10">
      ניצור איתך קשר בקרוב.
    </p>
    <a
      href={base}
      class="inline-block bg-burgundy hover:bg-burgundy-dark text-white text-lg font-bold px-10 py-4 rounded-full transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-burgundy"
    >
      חזרה לדף הבית
    </a>
  </section>

</BaseLayout>
