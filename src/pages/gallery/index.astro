---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const CDN = 'https://res.cloudinary.com/gmhtrfql/image/upload/f_auto,q_auto';

function src(id: string, w: number) {
  return `${CDN},w_${w},c_fill/${id}`;
}

function srcset(id: string) {
  return `${src(id, 400)} 400w, ${src(id, 800)} 800w, ${src(id, 1200)} 1200w`;
}

const years = [
  { year: '2023', cover: '2023-cover', label: '2023' },
  { year: '2024', cover: '2024-cover', label: '2024' },
  { year: '2025', cover: '2025-cover', label: '2025' },
];
---

<BaseLayout
  title="גלריה — תערוכת הסריגה השנתית"
  description="גלריית תמונות מתערוכות הסריגה השנתיות 2023, 2024 ו-2025"
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16" dir="rtl">
    <h1 class="text-4xl sm:text-5xl font-abraham text-burgundy text-center mb-12">גלריה</h1>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-8">
      {years.map(({ year, cover, label }) => (
        <a
          href={`${base}gallery/${year}`}
          class="group block rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-burgundy"
          aria-label={label}
        >
          <div class="aspect-[3/4] overflow-hidden">
            <img
              src={src(cover, 800)}
              srcset={srcset(cover)}
              sizes="(min-width: 640px) 33vw, 50vw"
              alt={label}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="bg-white p-4 text-center">
            <h2 class="text-xl font-bold text-burgundy">{label}</h2>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
